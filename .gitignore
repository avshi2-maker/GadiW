# ─────────────────────────────────────────
# .gitignore — GadiW project (merged: Vite + security)
# ─────────────────────────────────────────

# ─── Environment / secrets (NEVER commit API keys) ───
.env
.env.local
.env.*.local
*.key
secrets/

# ─── Logs ───
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─── Node.js dependencies ───
node_modules/
package-lock.json.backup

# ─── Build outputs ───
dist
dist-ssr
*.local

# ─── Python virtual environments ───
venv/
env/
__pycache__/
*.pyc
*.pyo

# ─── Editor / IDE files ───
.vscode/*
!.vscode/extensions.json
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~

# ─── OS junk files ───
Thumbs.db
.DS_Store
desktop.ini

# ─── Temporary work / backups ───
tmp/
temp/
*.bak
*_backup.*
*_old.*

# ─── Uploaded files that should not be versioned ───
uploads/private/
test_audio/
# Python migration script
migration/venv/
migration/.env
migration/__pycache__/
migration/*.pyc
migration/migration_log_*.txt
migration/gadi_inventory_*.xlsx
migration/client_review_*.xlsx
migration/test_files/



# Handover docs (kept locally, not in git)
GadiW_Migration_Day_Bible_*.docx
